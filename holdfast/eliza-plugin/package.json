{
  "name": "@holdfastprotocol/eliza-plugin",
  "version": "0.1.0-devnet.1",
  "description": "Holdfast Protocol reputation and escrow plugin for ElizaOS agents",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test src/tests/configValidation.test.ts src/tests/actions.test.ts src/tests/providers.test.ts src/tests/escrowEventListener.test.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@elizaos/core": "^1.0.0"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@holdfastprotocol/sdk": "0.2.0-devnet.1",
    "bs58": "^6.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@elizaos/core": "^1.0.0",
    "@types/node": "^20.19.39",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "elizaos",
    "eliza-plugin",
    "holdfast-protocol",
    "solana",
    "reputation",
    "escrow",
    "agent"
  ],
  "license": "MIT"
}
