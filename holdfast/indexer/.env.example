# VaultPact Indexer — environment variables
# Copy to .env and fill in values before running locally.

# Solana program to subscribe to (must match the deployed VaultPact program ID)
PROGRAM_ID=D6mUa4wGtFyLyJorMfxoKvA9ybohjUSsfw88t66ATxg

# Solana JSON-RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com

# Solana WebSocket endpoint (derived from SOLANA_RPC_URL if omitted)
# SOLANA_WS_URL=wss://api.devnet.solana.com

# SQLite database path (use an absolute path or a volume mount in production)
DB_PATH=reputation.db

# HTTP API port
PORT=3001
