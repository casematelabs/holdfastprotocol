# ── Required ─────────────────────────────────────────────────────────────────
# Discord incoming webhook URL for the #protocol-health channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Service endpoints ─────────────────────────────────────────────────────────
# Holdfast indexer base URL (no trailing slash)
INDEXER_URL=http://localhost:3000

# Solana devnet RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Optional: oracle process health endpoint. If not set, oracle health checks are skipped.
# ORACLE_URL=http://localhost:8080

# ── Program IDs ───────────────────────────────────────────────────────────────
# Override defaults only when deploying to a non-standard environment
# HOLDFAST_PROGRAM_ID=D6mUa4wGtFyLyJorMfxoKvA9ybohjUSsfw88t66ATxg
# ESCROW_PROGRAM_ID=BNxA76z6vjQYtUJXGpH8qjA3wHvtAAqGqL6rvVWH6b3H

# ── Program binary hash baselines ─────────────────────────────────────────────
# SHA-256 of the deployed program data. If set, the bot alerts on any hash change.
# Run `solana program dump <PROGRAM_ID> /tmp/prog.so && sha256sum /tmp/prog.so` to generate.
# HOLDFAST_PROGRAM_BASELINE_HASH=
# ESCROW_PROGRAM_BASELINE_HASH=

# ── Alert behaviour ───────────────────────────────────────────────────────────
# Seconds before re-alerting for the same ongoing failure (default 300 = 5 min)
# ALERT_COOLDOWN_SECONDS=300

# Maximum allowed slot lag between processed and confirmed (default 100)
# RPC_SLOT_LAG_THRESHOLD=100

# ── Poll intervals (seconds) ──────────────────────────────────────────────────
# INDEXER_POLL_INTERVAL_SECONDS=60
# ESCROW_POLL_INTERVAL_SECONDS=60
# ORACLE_POLL_INTERVAL_SECONDS=300
# PROGRAM_POLL_INTERVAL_SECONDS=600
# RPC_POLL_INTERVAL_SECONDS=300
