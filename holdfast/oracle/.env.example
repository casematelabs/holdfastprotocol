# Holdfast Oracle — environment configuration
# Copy to .env or export these vars before running `npm start` / `npm run dev`.
# All values below are the devnet defaults. Override as needed.

# ── RPC & Program IDs ─────────────────────────────────────────────────────────
# Solana JSON-RPC endpoint. Defaults to public devnet.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Holdfast vaultpact program deployed on devnet.
HOLDFAST_PROGRAM_ID=2chF47DbqehX3L38874e2RznaSs46vpcMPEPRYz4Dywq

# Holdfast escrow program — source of VaultPactDisputeSettled log events.
ESCROW_PROGRAM_ID=BNxA76z6vjQYtUJXGpH8qjA3wHvtAAqGqL6rvVWH6b3H

# Solana Agent Registry program. Leave unset until CAS-45 confirms the devnet address.
# AGENT_REGISTRY_PROGRAM_ID=

# ATOM Engine and bridge programs (devnet — live as of CAS-60).
ATOM_ENGINE_PROGRAM_ID=AToMufS4QD6hEXvcvBDg9m1AHeCLpmZQsyfYa5h9MwAF
ATOM_BRIDGE_PROGRAM_ID=5dDk9suKgyS9QqbgRf3Fet6v3sa37VsACsVaJFBgZg92
ATOM_BRIDGE_CONFIG=GFk2wGMVakcS3AwM6P8orW33zcY1n2xBjtjJEcbR49zn

# ── Oracle Keypair ────────────────────────────────────────────────────────────
# The oracle authority keypair must match REPUTATION_ORACLE_AUTHORITY in the
# vaultpact program. Two mutually exclusive options:
#
# Option A (file path — preferred for local dev):
ORACLE_KEYPAIR_PATH=~/.config/solana/oracle-devnet.json
#
# Option B (inline JSON — preferred for CI/containers):
# ORACLE_KEYPAIR_JSON=[1,2,3,...,64]   # 64-byte secret key as JSON array
#
# SECURITY: restrict keypair file permissions: chmod 600 ~/.config/solana/oracle-devnet.json
# Never commit the actual keypair file or the ORACLE_KEYPAIR_JSON value.

# ── Vote / Reputation ─────────────────────────────────────────────────────────
# Hours before the oracle logs a missed-vote warning for a pending dispute.
# Per CAS-11 §3.4 the production SLA is 72h. Reduce for testing.
VOTE_TIMEOUT_HOURS=72

# ── IDL Path (optional override) ──────────────────────────────────────────────
# Path to holdfast/target/idl/vaultpact.json. Only needed when the oracle is
# run from a non-standard location or after moving build artifacts.
# Default resolves to ../../target/idl/vaultpact.json relative to dist/index.js.
# VAULTPACT_IDL_PATH=/path/to/holdfast/target/idl/vaultpact.json

# ── ATOM Engine Trust Signals (optional) ──────────────────────────────────────
# Periodic trust signal target. If both are set, the oracle emits a stub trust
# signal every ATOM_SIGNAL_INTERVAL_SECONDS seconds. Defaults to devnet test
# accounts verified in CAS-60. Set to empty to disable.
# ATOM_LEGIT_SNAPSHOT=CoqRXe2K5X52SCHfzFpbNwS1bhFZ2KyyQBnvcyxZP1d5
# ATOM_STATS_PUBKEY=KMqMvMkw2S6rKQMBKbQYvGFFigYwQp4aCQWJzDVCScg
ATOM_SIGNAL_INTERVAL_SECONDS=30
