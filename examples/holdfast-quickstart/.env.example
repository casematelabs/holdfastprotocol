# ── Required ──────────────────────────────────────────────────────────────────
#
# Path to your Solana keypair JSON file (the initiator / payer account).
#
# Generate one if you don't have it:
#   solana-keygen new -o ~/.config/solana/devnet.json
#
# Airdrop devnet SOL:
#   solana airdrop 2 --url devnet
#
# Wrap SOL into wSOL (needed to fund the escrow vault):
#   spl-token wrap 0.1 --fee-payer ~/.config/solana/devnet.json
#
KEYPAIR_PATH=~/.config/solana/devnet.json

# ── Optional ──────────────────────────────────────────────────────────────────
#
# Path to a second keypair to use as the counterparty (beneficiary).
# When omitted, the same keypair acts as both sides ("self-pact" demo).
# A self-pact is safe on devnet and exercises the complete flow.
#
# COUNTERPARTY_KEYPAIR_PATH=~/.config/solana/devnet-counterparty.json

# Override the RPC endpoint (defaults to Solana public devnet).
# Use a private RPC for higher rate limits during testing.
#
# RPC_URL=https://api.devnet.solana.com
