# Local development overrides for the Holdfast Protocol dashboard.
# Copy to .env.local (gitignored) and adjust before running `next dev`.

# Point the dashboard at a locally-running indexer instead of the production Fly.dev host.
# Start the local indexer first:
#   cd holdfast/indexer && npm run build && node dist/index.js
# Health check: http://localhost:3001/health
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001

# Optional: override the Solana RPC endpoint (defaults to devnet in release-manifest.json)
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
